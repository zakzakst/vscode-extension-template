{
  "name": "vscode-extension-template",
  "publisher": "zakzakst",
  "displayName": "",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-extension-template.sample",
        "title": "コマンドサンプル"
      },
      {
        "command": "vscode-extension-template.context-sample",
        "title": "右クリック コマンドサンプル"
      }
    ],
    "configuration": {
      "title": "サンプル",
      "properties": {
        "vscode-extension-template.sample": {
          "type": "string",
          "default": "",
          "description": "サンプルテキスト"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sample",
          "title": "サンプル",
          "icon": "media/icon-sample.svg"
        }
      ]
    },
    "views": {
      "sample": [
        {
          "id": "sampleView",
          "name": "サンプル",
          "icon": "media/icon-sample.svg"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "vscode-extension-template.sample",
          "when": "viewItem == context-sample"
        },
        {
          "command": "vscode-extension-template.context-sample",
          "when": "viewItem == context-sample"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "package:vsce": "vsce package --out downloads --allow-missing-repository",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "lint:prettier": "prettier . --write",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
